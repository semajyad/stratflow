#!/bin/sh
# pre-push — run Playwright fast suite before any push.
#
# Catches browser-layer regressions (CSRF failures, JS parse errors on API
# responses, broken page loads) that unit tests cannot see.
#
# Requires: Docker container stratflow-php-1 running + Playwright installed.
# Bypass: SKIP_PLAYWRIGHT=1 git push  (emergency use only — add a comment why)

if [ "${SKIP_PLAYWRIGHT}" = "1" ]; then
    echo "[pre-push] Playwright check skipped (SKIP_PLAYWRIGHT=1)."
    exit 0
fi

# Check Docker is available and the app container is up
if ! command -v docker > /dev/null 2>&1; then
    echo "[pre-push] Docker not found — cannot run Playwright. Install Docker or set SKIP_PLAYWRIGHT=1."
    exit 1
fi

if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q 'stratflow-php-1'; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  Playwright browser check blocked                            ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  stratflow-php-1 is not running.                            ║"
    echo "║  Start it: docker compose up -d                             ║"
    echo "║  Then re-push, or bypass: SKIP_PLAYWRIGHT=1 git push       ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
PW_DIR="$REPO_ROOT/tests/Playwright"

if [ ! -f "$PW_DIR/node_modules/.bin/playwright" ] && [ ! -f "$PW_DIR/node_modules/.bin/playwright.cmd" ]; then
    echo "[pre-push] Playwright not installed in tests/Playwright/. Run: cd tests/Playwright && npm install"
    echo "           Or bypass: SKIP_PLAYWRIGHT=1 git push"
    exit 1
fi

echo "[pre-push] Running Playwright fast suite..."
cd "$PW_DIR" || exit 1

npx playwright test --project=fast 2>&1
PW_EXIT=$?

if [ $PW_EXIT -ne 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  Push blocked: Playwright fast suite failed                  ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  Fix the failing tests before pushing.                      ║"
    echo "║  See output above for details.                              ║"
    echo "║  Emergency bypass: SKIP_PLAYWRIGHT=1 git push               ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    exit 1
fi

echo "[pre-push] Playwright fast suite passed. ✓"
exit 0
