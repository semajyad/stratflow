#!/bin/sh
# --- vexp start ---

# Generated by vexp — sync index after checkout
# $3 = 1 if branch checkout, 0 if file checkout
if [ "$3" = "0" ]; then
    : # skip file checkouts
else
    VEXP_CORE=""
    if command -v vexp-core > /dev/null 2>&1; then
        VEXP_CORE="vexp-core"
    fi
    if [ -n "$VEXP_CORE" ]; then
        "$VEXP_CORE" index --checkout-sync > /dev/null 2>&1 || true
    fi
fi
# --- vexp end ---
