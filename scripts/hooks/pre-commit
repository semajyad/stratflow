#!/bin/sh
# --- vexp start ---

# Generated by vexp — finalize index before commit
VEXP_CORE=""
if command -v vexp-core > /dev/null 2>&1; then
    VEXP_CORE="vexp-core"
elif [ -f "$(git rev-parse --git-dir)/../node_modules/.bin/vexp-core" ]; then
    VEXP_CORE="$(git rev-parse --git-dir)/../node_modules/.bin/vexp-core"
fi
if [ -n "$VEXP_CORE" ]; then
    "$VEXP_CORE" index --finalize > /dev/null 2>&1 || true
    git add .vexp/manifest.json 2>/dev/null || true
fi
# --- vexp end ---

# --- php-lint start ---
# Fast syntax check on staged PHP files — no Docker needed.
# Catches parse errors before the slower coverage gate runs.
STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$')
if [ -n "$STAGED_PHP" ]; then
    LINT_FAILED=0
    for f in $STAGED_PHP; do
        php -l "$f" > /dev/null 2>&1 || {
            echo "[pre-commit] PHP syntax error in: $f"
            php -l "$f" 2>&1 | grep -v '^$'
            LINT_FAILED=1
        }
    done
    if [ $LINT_FAILED -ne 0 ]; then
        echo ""
        echo "Commit blocked: fix PHP syntax errors above."
        exit 1
    fi
fi
# --- php-lint end ---

# --- coverage gate start ---
# Enforce ≥80% unit test coverage for every touched src/ PHP file.
# Requires: Docker container stratflow-php-1 running with Xdebug installed.
# Skip by setting: SKIP_COVERAGE_CHECK=1 git commit ...
if [ "${SKIP_COVERAGE_CHECK}" != "1" ]; then
    STAGED_SRC=$(git diff --cached --name-only --diff-filter=ACM | grep '^src/.*\.php$')
    if [ -n "$STAGED_SRC" ]; then
        FILE_LIST=$(echo "$STAGED_SRC" | tr '\n' ',')
        echo "[pre-commit] Running coverage gate for: $(echo "$STAGED_SRC" | tr '\n' ' ')"
        docker exec stratflow-php-1 sh -c \
            "cd /var/www/html && php scripts/ci/check_coverage.php '$FILE_LIST'"
        COVERAGE_EXIT=$?
        if [ $COVERAGE_EXIT -ne 0 ]; then
            echo ""
            echo "Commit blocked: coverage gate failed (see above)."
            echo "Fix: add tests, or set SKIP_COVERAGE_CHECK=1 to bypass."
            exit 1
        fi
    fi
fi
# --- coverage gate end ---

# --- bug-test gate start ---
# Enforce: any commit message starting with "fix:" must include a test file change.
# Skip by setting: SKIP_COVERAGE_CHECK=1 git commit ...
if [ "${SKIP_COVERAGE_CHECK}" != "1" ]; then
    COMMIT_MSG_FILE="$(git rev-parse --git-dir)/COMMIT_EDITMSG"
    if [ -f "$COMMIT_MSG_FILE" ]; then
        SUBJECT=$(head -1 "$COMMIT_MSG_FILE" | tr '[:upper:]' '[:lower:]')
    else
        SUBJECT=""
    fi

    case "$SUBJECT" in
        fix:*|fix\(*\):*|fix\(*\)!:*)
            STAGED_TESTS=$(git diff --cached --name-only --diff-filter=ACM | grep '^tests/.*\.php$')
            if [ -z "$STAGED_TESTS" ]; then
                echo ""
                echo "╔══════════════════════════════════════════════════════════════╗"
                echo "║  Bug-test rule violated                                      ║"
                echo "╠══════════════════════════════════════════════════════════════╣"
                echo "║  Commits starting with 'fix:' must include a regression     ║"
                echo "║  test that proves the bug is fixed and won't regress.        ║"
                echo "║                                                              ║"
                echo "║  Add or update a test file under tests/ and stage it.       ║"
                echo "║  To bypass (use sparingly): SKIP_COVERAGE_CHECK=1           ║"
                echo "╚══════════════════════════════════════════════════════════════╝"
                exit 1
            fi
            ;;
    esac
fi
# --- bug-test gate end ---

# --- docs-check start ---
# Enforce: documentation must be updated when tracked source files change.
# See scripts/ci/check_docs.py for the full rule set.
# Skip by setting: SKIP_DOCS_CHECK=1 git commit ...
if [ "${SKIP_DOCS_CHECK}" != "1" ]; then
    PYTHON=""
    for candidate in python3 python; do
        if command -v "$candidate" > /dev/null 2>&1; then
            if "$candidate" -c "import sys; sys.exit(0 if sys.version_info >= (3,8) else 1)" 2>/dev/null; then
                PYTHON="$candidate"
                break
            fi
        fi
    done
    DOCS_SCRIPT="$(git rev-parse --show-toplevel)/scripts/ci/check_docs.py"
    if [ -n "$PYTHON" ] && [ -f "$DOCS_SCRIPT" ]; then
        "$PYTHON" "$DOCS_SCRIPT" --staged
        DOCS_EXIT=$?
        if [ $DOCS_EXIT -ne 0 ]; then
            echo ""
            echo "Commit blocked: update the listed documentation files, then re-commit."
            echo "To bypass (emergency only): SKIP_DOCS_CHECK=1 git commit ..."
            exit 1
        fi
    fi
fi
# --- docs-check end ---
