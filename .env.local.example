APP_ENV=local
APP_URL=http://localhost:8890
APP_DEBUG=true
# Must be a base64-encoded 32-byte key. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
# Optional key rotation list read by SecretManager: kid:base64-32-byte-key,kid2:base64-32-byte-key
TOKEN_ENCRYPTION_KEYS=local-1:MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=,local-2:ZmVkY2JhOTg3NjU0MzIxMGZlZGNiYTk4NzY1NDMyMTA=
ALLOW_EXTERNAL_AI_PROCESSING=false

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=stratflow
DB_USERNAME=stratflow
DB_PASSWORD=stratflow_secret

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_PRODUCT=price_placeholder
STRIPE_PRICE_CONSULTANCY=price_placeholder
STRIPE_PRICE_USER_PACK=price_placeholder
STRIPE_PRICE_EVAL_BOARD=price_placeholder

RESEND_API_KEY=
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=
MAIL_FROM_NAME="StratFlow Local"
MAIL_FROM_EMAIL=local@example.test
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_ENCRYPTION=auto
MAIL_SMTP_USER=
MAIL_SMTP_PASS=

GITHUB_APP_ID=
GITHUB_APP_SLUG=
