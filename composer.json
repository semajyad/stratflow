{
    "name": "threepoints/stratflow",
    "description": "AI-powered strategy to work items platform",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "sentry/sentry": "^4.0",
        "smalot/pdfparser": "^2.0",
        "stripe/stripe-php": "^16.0",
        "vlucas/phpdotenv": "^5.6",
        "growthbook/growthbook": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^4.0",
        "infection/infection": "^0.32"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "StratFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StratFlow\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration tests/phpunit.xml",
        "test:unit": "phpunit --configuration tests/phpunit.xml --testsuite unit",
        "test:integration": "phpunit --configuration tests/phpunit.xml --testsuite integration"
    }
}
