APP_ENV=local
APP_URL=http://localhost:8890
APP_DEBUG=true

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=stratflow
DB_USERNAME=stratflow
DB_PASSWORD=stratflow_secret

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRODUCT=price_xxx
STRIPE_PRICE_CONSULTANCY=price_xxx
STRIPE_PRICE_USER_PACK=price_xxx
STRIPE_PRICE_EVAL_BOARD=price_xxx

RESEND_API_KEY=your-resend-api-key

MAIL_FROM_NAME=StratFlow System
MAIL_FROM_EMAIL=support@threepoints.info
MAIL_SMTP_HOST=mail.threepoints.info
MAIL_SMTP_PORT=465
MAIL_SMTP_USER=support@threepoints.info
MAIL_SMTP_PASS=your-smtp-password

GITHUB_APP_ID=your-github-app-id
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_APP_WEBHOOK_SECRET=your-github-app-webhook-secret
# On Railway/PaaS: paste PEM content here (newlines as \n or literal)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# On local Docker: use a file path instead (GITHUB_APP_PRIVATE_KEY takes precedence if set)
# GITHUB_APP_PRIVATE_KEY_PATH=/var/secrets/github-app.pem

JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret

XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret

UPLOAD_MAX_SIZE=52428800

