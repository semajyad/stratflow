{
    "source": {
        "directories": ["src"],
        "excludes": [
            "src/Services/Prompts",
            "src/Config"
        ]
    },
    "tmpDir": ".infection-tmp",
    "logs": {
        "text": "var/infection.log",
        "html": "var/infection.html",
        "summary": "var/infection-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 70,
    "minCoveredMsi": 80,
    "testFramework": "phpunit",
    "phpUnit": {
        "configDir": "tests"
    },
    "testFrameworkOptions": "--configuration=tests/phpunit.xml",
    "threads": 2
}
